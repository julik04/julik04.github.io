sourcesContent":["import \"../App.css\";\n\nfunction AboutStudio () {\n    return (\n        <div className=\"about_studio\">\n            <div className=\"container\">\n                <div className=\"article_about\">\n                    <h1 className=\"about_heading\">\n                        О нашей студии\n                    </h1>\n                    <div className=\"studio_columns\">\n                        <div className=\"article\">\n                            <h3 className=\"article_heading\">\n                                Команда Black Lotus\n                            </h3>\n                            <p className=\"article_para\">\n                                Под брендом студии «Black Lotus» объединили творческие стремления \n                                мастера с богатым опытом работы и знакомые не первый год, поэтому \n                                в студии всегда царит уютная домашняя обстановка. Мы не завышаем стоимость\n                                работ, растягивая количество сеансов. Каждый мастер нашей студии – это \n                                профессионал, который уже заработал солидную репутацию среди клиентов и коллег. \n                                Мы уверены, что любая модификация тела – это одновременно веселая и оригинальная \n                                синергия моды, искусства и ремесла, так и ответственный шаг и процедура повышенной \n                                опасности, поэтому в нашей студии каждый член команды осознает свою ответственность, \n                                и всегда помнит о том, что должен поддерживать свой высокий профессиональный уровень.\n                            </p>\n                            <p className=\"article_para\">\n                                Если Вы решили изменить себя или только думаете об этом, \n                                приглашаем в комфортной обстановке представить, обсудить и \n                                реализовать свои идеи вместе с нами. Мы открыты ежедневно и очень \n                                рады гостям нашей студии.\n                            </p>\n                        </div>\n                        <div className=\"article\">\n                            <h3 className=\"article_heading\">\n                                Студии и Магазин Украшений\n                            </h3>\n                            <p className=\"article_para\">\n                                Уютная студия в центре Петербурга с отдельными кабинетами, где топ-мастера \n                                помогут воплотить любые фантазии о вашем визуальном образе. Располагается \n                                на улице 2-я Советская.\n                            </p>\n                            <p className=\"article_para\">\n                                Здесь вы сможете найти все необходимое для своего творчества и \n                                самовыражения. Наша команда мастеров с радостью приветствует вас \n                                в этом новом пространстве.\n                            </p>\n                            <p className=\"article_para\">\n                                Наша студия открыта не только для людей желающих изменить \n                                свою внешность, но и для тех, кто сам хочет стать мастером тату \n                                или пирсинга. Мы проводим индивидуальные занятия по свободному графику \n                                и предоставляем стажировку на живых моделях. Лучшие ученики имеют\n                                возможность попасть в команду HurtLand. Если у Вас есть другие вопросы, \n                                творческие или коммерческие предложения мы рады рассмотреть их.\n                            </p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    )\n}\n\nexport default AboutStudio;"],"mappings":";AAAA,OAAO,YAAY;AAAC,SAAAA,MAAA,IAAAC,OAAA;AAEpB,SAASC,WAAWA,CAAA,EAAI;EACpB,oBACID,OAAA;IAAKE,SAAS,EAAC,cAAc;IAAAC,QAAA,eACzBH,OAAA;MAAKE,SAAS,EAAC,WAAW;MAAAC,QAAA,eACtBH,OAAA;QAAKE,SAAS,EAAC,eAAe;QAAAC,QAAA,gBAC1BH,OAAA;UAAIE,SAAS,EAAC,eAAe;UAAAC,QAAA,EAAC;QAE9B;UAAAC,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAI,CAAC,eACLP,OAAA;UAAKE,SAAS,EAAC,gBAAgB;UAAAC,QAAA,gBAC3BH,OAAA;YAAKE,SAAS,EAAC,SAAS;YAAAC,QAAA,gBACpBH,OAAA;cAAIE,SAAS,EAAC,iBAAiB;cAAAC,QAAA,EAAC;YAEhC;cAAAC,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAI,CAAC,eACLP,OAAA;cAAGE,SAAS,EAAC,cAAc;cAAAC,QAAA,EAAC;YAU5B;cAAAC,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAG,CAAC,eACJP,OAAA;cAAGE,SAAS,EAAC,cAAc;cAAAC,QAAA,EAAC;YAK5B;cAAAC,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAG,CAAC;UAAA;YAAAH,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACH,CAAC,eACNP,OAAA;YAAKE,SAAS,EAAC,SAAS;YAAAC,QAAA,gBACpBH,OAAA;cAAIE,SAAS,EAAC,iBAAiB;cAAAC,QAAA,EAAC;YAEhC;cAAAC,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAI,CAAC,eACLP,OAAA;cAAGE,SAAS,EAAC,cAAc;cAAAC,QAAA,EAAC;YAI5B;cAAAC,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAG,CAAC,eACJP,OAAA;cAAGE,SAAS,EAAC,cAAc;cAAAC,QAAA,EAAC;YAI5B;cAAAC,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAG,CAAC,eACJP,OAAA;cAAGE,SAAS,EAAC,cAAc;cAAAC,QAAA,EAAC;YAO5B;cAAAC,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAG,CAAC;UAAA;YAAAH,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACH,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACL,CAAC;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACL;IAAC;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACL;EAAC;IAAAH,QAAA,EAAAC,YAAA;IAAAC,UAAA;IAAAC,YAAA;EAAA,OACL,CAAC;AAEd;AAACC,EAAA,GA3DQP,WAAW;AA6DpB,eAAeA,WAAW;AAAC,IAAAO,EAAA;AAAAC,YAAA,CAAAD,EAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}